# ============================================================
# AI Assistant Platform - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ---- Server ----
PORT=3000
NODE_ENV=development

# ---- AI Providers ----
# Set PRIMARY_AI_PROVIDER to 'claude' or 'openai'
PRIMARY_AI_PROVIDER=claude

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI (optional alternative)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ---- WhatsApp Interface (Twilio) ----
# Sign up at https://www.twilio.com/
# Enable WhatsApp Sandbox: https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ---- Tool Integrations ----

# Notion
# Create integration: https://www.notion.so/my-integrations
NOTION_API_KEY=your_notion_api_key
NOTION_DEFAULT_DATABASE_ID=your_default_database_id

# Google (Calendar, Drive, Gmail)
# Create credentials: https://console.cloud.google.com/
# Download credentials.json and place in project root
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_TOKEN_PATH=./token.json

# ---- Session Config ----
SESSION_TTL_HOURS=24
MAX_CONVERSATION_HISTORY=50
